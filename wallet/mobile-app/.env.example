# Laravel host only (no path). The app calls JSON endpoints under /api/v1 on this host.
# Same host as `php artisan serve --host=0.0.0.0` — use this machine’s LAN IP for phone/simulator on Wi‑Fi.
# Use http:// only for local dev; production/staging should use https:// (Android cleartext is off when URL is https).
EXPO_PUBLIC_API_URL=http://192.168.100.215:8000
